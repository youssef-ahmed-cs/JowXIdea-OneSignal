{
    "name": "jowxidea/onesignal",
    "description": "A lightweight and easy-to-use Laravel package for integrating OneSignal push notifications into your application.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "onesignal",
        "notifications",
        "push",
        "notification-service",
        "laravel - flutter - front"
    ],
    "autoload": {
        "psr-4": {
            "Jowxidea\\Onesignal\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Jowxidea\\Onesignal\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "yes"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Jowxidea\\Onesignal\\OneSignalServiceProvider"
            ],
            "aliases": {
                "OneSignal": "Jowxidea\\Onesignal\\Facades\\OneSignal"
            }
        }
    },
    "scripts": {
        "test": "@php vendor/bin/phpunit --colors=always"
    }
}
